# Top‑level gitignore for the entire project

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
venv/
env/
env/
*.env

# Results and temporary data
/results/
/data/*.json

# Node/Angular
/frontend/node_modules/
/frontend/dist/
/frontend/.angular/
/frontend/coverage/

# IDE/editor folders
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db

# Logs
*.log

# Misc
*.swp
*.bak
