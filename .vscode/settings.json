{
  "latex-workshop.latex.recipes": [
    {
      "name": "pdfLaTeX with shell-escape → biber → pdfLaTeX × 2",
      "tools": ["pdflatex-shell-escape", "biber", "pdflatex-shell-escape", "pdflatex-shell-escape"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex-shell-escape",
      "command": "pdflatex",
      "args": ["--shell-escape", "-synctex=1", "-interaction=nonstopmode", "-file-line-error", "%DOC%"],
      "env": {}
    },
    {
      "name": "biber",
      "command": "biber",
      "args": ["%DOCFILE%"],
      "env": {}
    }
  ],
  "latex-workshop.latex.autoBuild.run": "never",
  "latex-workshop.latex.outDir": "./",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bbl",
    "*.blg",
    "*.idx",
    "*.ind",
    "*.lof",
    "*.lot",
    "*.out",
    "*.toc",
    "*.acn",
    "*.acr",
    "*.alg",
    "*.glg",
    "*.glo",
    "*.gls",
    "*.ist",
    "*.fls",
    "*.log",
    "*.fdb_latexmk",
    "*.snm",
    "*.nav",
    "*.vrb",
    "*.bcf",
    "*.run.xml",
    "*.synctex.gz"
  ]
}
